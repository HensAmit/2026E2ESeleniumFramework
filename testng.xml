<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
        <listener class-name="com.framework.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="UI Tests">
        <parameter name="env" value="qa"/>
        <classes>
            <class name="com.tests.tests.LoginTest"/>
            <class name="com.tests.tests.DashboardTest"/>
        </classes>
    </test>

</suite>